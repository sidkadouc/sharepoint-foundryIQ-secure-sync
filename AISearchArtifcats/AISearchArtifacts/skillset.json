{
  "name": "${skillsetName}",
  "description": "Skillset with OCR, text chunking, and GPT-4o image verbalization",
  "cognitiveServices": {
    "@odata.type": "#Microsoft.Azure.Search.AIServicesByIdentity",
    "subdomainUrl": "${cognitiveServicesResourceUri}"
  },
  "skills": [
    {
      "@odata.type": "#Microsoft.Skills.Vision.OcrSkill",
      "name": "ocr-skill",
      "description": "OCR skill to extract text from images",
      "context": "/document/normalized_images/*",
      "lineEnding": "Space",
      "defaultLanguageCode": "fr",
      "detectOrientation": true,
      "inputs": [
        {
          "name": "image",
          "source": "/document/normalized_images/*"
        }
      ],
      "outputs": [
        {
          "name": "text",
          "targetName": "text"
        }
      ]
    },
    {
      "@odata.type": "#Microsoft.Skills.Custom.ChatCompletionSkill",
      "uri": "${openAIResourceUri}/openai/deployments/${chatCompletionDeploymentId}/chat/completions?api-version=2024-08-01-preview",
      "timeout": "PT1M",
      "name": "image-verbalization-skill",
      "description": "GPT-4o skill for image verbalization",
      "context": "/document/normalized_images/*",
      "inputs": [
        {
          "name": "systemMessage",
          "source": "='Vous êtes chargé de générer des descriptions concises et précises des images dans les documents juridiques. L objectif est de capturer les informations clés et le sens véhiculé par l image.\n\nInstructions:\n- Pour les photos de scènes (accidents, preuves): décrivez les véhicules, dommages visibles, marques, plaques, environnement, personnes présentes.\n- Pour les documents d identité: décrivez le type de document, les informations visibles (nom, photo, numéros).\n- Pour les graphiques/diagrammes: identifiez les éléments principaux et leurs relations.\n- Soyez précis et factuel pour un contexte juridique ou d enquête.\n- Incluez tout texte visible dans l image.'"
        },
        {
          "name": "userMessage",
          "source": "='Décrivez cette image en détail pour un dossier juridique. Incluez tous les éléments visuels pertinents.'"
        },
        {
          "name": "image",
          "source": "/document/normalized_images/*/data"
        }
      ],
      "outputs": [
        {
          "name": "response",
          "targetName": "verbalizedImage"
        }
      ]
    },
    {
      "@odata.type": "#Microsoft.Skills.Text.MergeSkill",
      "name": "merge-skill",
      "description": "Merge OCR text and image descriptions with document content",
      "context": "/document",
      "insertPreTag": " ",
      "insertPostTag": " ",
      "inputs": [
        {
          "name": "text",
          "source": "/document/content"
        },
        {
          "name": "itemsToInsert",
          "source": "/document/normalized_images/*/verbalizedImage"
        },
        {
          "name": "offsets",
          "source": "/document/normalized_images/*/contentOffset"
        }
      ],
      "outputs": [
        {
          "name": "mergedText",
          "targetName": "mergedText"
        }
      ]
    },
    {
      "@odata.type": "#Microsoft.Skills.Text.SplitSkill",
      "name": "split-skill",
      "description": "Split skill to chunk documents",
      "context": "/document",
      "defaultLanguageCode": "fr",
      "textSplitMode": "pages",
      "maximumPageLength": 2000,
      "pageOverlapLength": 200,
      "unit": "characters",
      "inputs": [
        {
          "name": "text",
          "source": "/document/mergedText"
        }
      ],
      "outputs": [
        {
          "name": "textItems",
          "targetName": "pages"
        }
      ]
    },
    {
      "@odata.type": "#Microsoft.Skills.Text.AzureOpenAIEmbeddingSkill",
      "name": "text-embedding-skill",
      "description": "Azure OpenAI Embedding skill for text chunks",
      "context": "/document/pages/*",
      "resourceUri": "${openAIResourceUri}",
      "deploymentId": "${embeddingDeploymentId}",
      "dimensions": ${embeddingDimensions},
      "modelName": "${embeddingModelName}",
      "authIdentity": null,
      "inputs": [
        {
          "name": "text",
          "source": "/document/pages/*"
        }
      ],
      "outputs": [
        {
          "name": "embedding",
          "targetName": "text_vector"
        }
      ]
    }
  ],
  "cognitiveServices": {
    "@odata.type": "#Microsoft.Azure.Search.DefaultCognitiveServices"
  },
  "indexProjections": {
    "selectors": [
      {
        "targetIndexName": "${indexName}",
        "parentKeyFieldName": "text_parent_id",
        "sourceContext": "/document/pages/*",
        "mappings": [
          {
            "name": "text_vector",
            "source": "/document/pages/*/text_vector"
          },
          {
            "name": "chunk",
            "source": "/document/pages/*"
          },
          {
            "name": "title",
            "source": "/document/title"
          },
          {
            "name": "case_id",
            "source": "/document/caseId"
          },
          {
            "name": "original_file_name",
            "source": "/document/originalFileName"
          },
          {
            "name": "UserIds",
            "source": "/document/UserIds"
          },
          {
            "name": "GroupIds",
            "source": "/document/GroupIds"
          }
        ]
      }
    ],
    "parameters": {
      "projectionMode": "skipIndexingParentDocuments"
    }
  }
}
