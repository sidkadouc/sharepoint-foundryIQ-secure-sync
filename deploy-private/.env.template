# ─────────────────────────────────────────────────────────────────────
# Private deployment environment template.
# Copy to ../.env.private and fill in values.
# ─────────────────────────────────────────────────────────────────────

# ── Azure basics ────────────────────────────────────────────────────
SUBSCRIPTION_ID=
RESOURCE_GROUP=rg-spsync-private
LOCATION=swedencentral

# ── Networking ──────────────────────────────────────────────────────
VNET_NAME=vnet-spsync
VNET_ADDRESS_PREFIX=10.0.0.0/16
SUBNET_PE_PREFIX=10.0.1.0/24
SUBNET_SYNC_PREFIX=10.0.2.0/24
SUBNET_AGENT_PREFIX=10.0.3.0/24

# ── SharePoint ──────────────────────────────────────────────────────
SHAREPOINT_SITE_URL=
SHAREPOINT_DRIVE_NAME=Documents
SHAREPOINT_FOLDER_PATH=/
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ── Resource names (auto-generated if blank) ────────────────────────
AZURE_STORAGE_ACCOUNT_NAME=
SEARCH_SERVICE_NAME=
OPENAI_RESOURCE_NAME=
COSMOSDB_ACCOUNT_NAME=

# ── Sync settings ──────────────────────────────────────────────────
AZURE_BLOB_CONTAINER_NAME=sharepoint-sync
AZURE_BLOB_PREFIX=
DELETE_ORPHANED_BLOBS=false
DRY_RUN=false
SYNC_PERMISSIONS=true
FORCE_FULL_SYNC=false
TIMER_SCHEDULE=0 0 2 * * *

# ── AI Search / Embedding ──────────────────────────────────────────
EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large
CHAT_DEPLOYMENT_NAME=gpt-4o
INDEX_NAME=sharepoint-index

# ── Foundry Agent ──────────────────────────────────────────────────
FOUNDRY_ACCOUNT_NAME=
FOUNDRY_PROJECT_NAME=spsync-agent
